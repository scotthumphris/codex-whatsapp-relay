{
  "name": "codex-whatsapp",
  "version": "0.4.3",
  "private": true,
  "type": "module",
  "description": "Repo-local Codex plugin for connecting and managing WhatsApp with terminal QR auth and app-server-backed phone control.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "whatsapp:auth": "node ./plugins/whatsapp-relay/scripts/whatsapp-auth.mjs",
    "whatsapp:controller": "node ./plugins/whatsapp-relay/scripts/controller-daemon.mjs",
    "whatsapp:install-chatterbox": "node ./plugins/whatsapp-relay/scripts/install-chatterbox.mjs",
    "whatsapp:mcp": "node ./plugins/whatsapp-relay/scripts/mcp-server.mjs",
    "whatsapp:status": "node ./plugins/whatsapp-relay/scripts/whatsapp-status.mjs",
    "whatsapp:tts:smoke": "node ./plugins/whatsapp-relay/scripts/voice-replier-smoke.mjs",
    "check": "node --check ./plugins/whatsapp-relay/scripts/*.mjs ./scripts/*.mjs",
    "test": "node --test ./plugins/whatsapp-relay/scripts/*.test.mjs ./scripts/*.test.mjs",
    "release:prepare": "node ./scripts/release.mjs"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "franc": "^6.2.0",
    "link-preview-js": "^3.2.0",
    "pino": "^9.9.4",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.1.11"
  }
}
